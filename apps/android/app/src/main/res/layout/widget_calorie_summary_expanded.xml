<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_eaten_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_zero"
                android:textColor="@color/widget_calorie_eaten"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/widget_eaten"
                android:textColor="@color/widget_calorie_text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <RelativeLayout
            android:layout_width="136dp"
            android:layout_height="136dp"
            android:layout_marginHorizontal="10dp">

            <ImageView
                android:id="@+id/widget_remaining_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/widget_remaining_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="42dp"
                android:text="@string/widget_zero"
                android:textColor="@color/widget_calorie_positive"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_remaining_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/widget_remaining_value"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="2dp"
                android:text="@string/widget_remaining"
                android:textColor="@color/widget_calorie_text_secondary"
                android:textSize="12sp" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_burned_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_zero"
                android:textColor="@color/widget_calorie_burned"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/widget_burned"
                android:textColor="@color/widget_calorie_text_secondary"
                android:textSize="10sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/widget_scan_button"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/widget_circle_button"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@string/widget_scan"
                        android:src="@drawable/ic_widget_qr" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/widget_add_button"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/widget_circle_button"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@string/widget_add_food"
                        android:src="@drawable/ic_widget_plus" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingEnd="8dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_carbs"
                android:textColor="@color/widget_calorie_text_primary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/widget_carbs_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/widget_macro_progress" />

            <TextView
                android:id="@+id/widget_carbs_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/widget_macro_value_placeholder"
                android:textColor="@color/widget_calorie_text_secondary"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingHorizontal="4dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_protein"
                android:textColor="@color/widget_calorie_text_primary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/widget_protein_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/widget_macro_progress" />

            <TextView
                android:id="@+id/widget_protein_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/widget_macro_value_placeholder"
                android:textColor="@color/widget_calorie_text_secondary"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_fat"
                android:textColor="@color/widget_calorie_text_primary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/widget_fat_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/widget_macro_progress" />

            <TextView
                android:id="@+id/widget_fat_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/widget_macro_value_placeholder"
                android:textColor="@color/widget_calorie_text_secondary"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
