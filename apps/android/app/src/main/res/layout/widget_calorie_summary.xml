<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:baselineAligned="false"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.9"
        android:gravity="center"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="84dp"
            android:layout_height="84dp">

            <ImageView
                android:id="@+id/widget_remaining_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/widget_remaining_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="25dp"
                android:text="@string/widget_zero"
                android:textColor="@color/widget_calorie_positive"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/widget_remaining_value"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="2dp"
                android:text="@string/widget_remaining"
                android:textColor="@color/widget_calorie_text_secondary"
                android:textSize="9sp" />
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="6dp"
        android:layout_weight="0.95"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_carbs"
            android:textColor="@color/widget_calorie_text_secondary"
            android:textSize="10sp" />

        <ProgressBar
            android:id="@+id/widget_carbs_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginTop="3dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_macro_progress" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/widget_protein"
            android:textColor="@color/widget_calorie_text_secondary"
            android:textSize="10sp" />

        <ProgressBar
            android:id="@+id/widget_protein_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginTop="3dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_macro_progress" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/widget_fat"
            android:textColor="@color/widget_calorie_text_secondary"
            android:textSize="10sp" />

        <ProgressBar
            android:id="@+id/widget_fat_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginTop="3dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_macro_progress" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.15"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widget_scan_button"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/widget_circle_button"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/widget_scan"
                android:src="@drawable/ic_widget_qr" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_add_button"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/widget_circle_button"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/widget_add_food"
                android:src="@drawable/ic_widget_plus" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
